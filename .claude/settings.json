{
  "permissions": {
    "allow": [
      "Bash(.venv/bin/pip3 install:*)",
      "Bash(.venv/bin/pip3 install -r requirements.txt)",
      "Bash(.venv/bin/pip3 uninstall:*)",
      "Bash(.venv/bin/pip3 list:*)",
      "Bash(.venv/bin/pip3 show:*)",
      "Bash(.venv/bin/pip3 index:*)",
      "Bash(.venv/bin/python3:*)",
      "Bash(.venv/bin/python3 -m pytest:*)",
      "Bash(python3 -m venv .venv)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "context7"
  ]
}
